SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Gemini (Rebi sohbet + bilgi tabanı PDF embedding / ingest için gerekli)
GEMINI_API_KEY=

# PDF RAG’ın bağlandığı katalog kullanıcı ID’si (ingest --user ile aynı olmalı). Boşsa varsayılan kullanılır.
# KNOWLEDGE_CATALOG_USER_ID=00000000-0000-4000-8000-000000000001

# Postgres (SQL migration / daily_events / knowledge ingest — Dashboard → Project Settings → Database)
# Tam URI (önerilir):
# SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# veya sadece veritabanı şifresi (SUPABASE_URL ile birlikte):
# SUPABASE_DB_PASSWORD=your-database-password
# İsteğe bağlı: scripts/apply_supabase_migration.py için (Dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=sbp_...
# Supabase Dashboard → Settings → API → JWT Secret (HS256). Doluysa API user_id ile Bearer doğrular.
# SUPABASE_JWT_SECRET=
# Üretimde boş bırakın. Demo UUID: 00000000-0000-4000-8000-000000000001 (+ eski demo-user-id,demo)
# API_JWT_BYPASS_USER_IDS=00000000-0000-4000-8000-000000000001,demo,demo-user-id
# Bu id'ler için Supabase yazımı yapılmaz (auth.users FK). JWT bypass ile aynı liste önerilir.
# API_DEMO_USER_IDS=00000000-0000-4000-8000-000000000001,demo-user-id,demo
# Çok süreç rate limit: redis://localhost:6379/0
# REDIS_URL=
OPENAI_API_KEY=sk-your-openai-key
OPENWEATHER_API_KEY=your-openweather-key
# Ücretsiz literatür ipuçları (RAG yokken): PubMed E-utilities, gerekirse Europe PMC
# PUBMED_FREE_HINTS=1
# NCBI_API_KEY=  # isteğe bağlı, ücretsiz: https://www.ncbi.nlm.nih.gov/account/settings/
# PUBMED_CONTACT_EMAIL=you@example.com  # NCBI nezaket; boş bırakılabilir
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
