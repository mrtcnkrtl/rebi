# Bu dosyayı deploy/.env.api olarak kopyalayın (asla git'e eklemeyin)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_KEY=
GEMINI_API_KEY=
OPENWEATHER_API_KEY=

# Üretim web kökenleri (virgülle)
CORS_ORIGINS=https://rebiovil.com,https://www.rebiovil.com,http://localhost:5173

# Önerilir: Dashboard → Settings → API → JWT Secret
# SUPABASE_JWT_SECRET=

# Üretimde boş veya kaldırın
# API_JWT_BYPASS_USER_IDS=
# API_DEMO_USER_IDS=

# Çok süreç / scale
# REDIS_URL=redis://redis:6379/0
